{
  "$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
  "files": {
    "includes": ["src/**/*.ts"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn",
        "noUnusedPrivateClassMembers": "off",
        "useExhaustiveDependencies": "off"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noConfusingVoidType": "off",
        "noAssignInExpressions": "off",
        "noTemplateCurlyInString": "off",
        "noImplicitAnyLet": "error",
        "useIterableCallbackReturn": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "warn",
        "noParameterAssign": "off",
        "useDefaultParameterLast": "off"
      },
      "complexity": {
        "noForEach": "off",
        "noStaticOnlyClass": "off"
      },
      "performance": {
        "noDelete": "off"
      }
    }
  },
  "formatter": {
    "enabled": false
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "src/**/*.test.ts",
        "src/**/*.integration.ts",
        "src/**/*.integration.test.ts",
        "src/**/testing/**",
        "src/**/test-utils/**",
        "src/**/__tests__/**",
        "src/**/__test-utils__/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noImplicitAnyLet": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/cli.ts",
        "src/core/loop/transport.ts",
        "src/modules/agent-ops/**",
        "src/modules/approval-queue/**",
        "src/modules/eval-harness/**",
        "src/modules/guardrails-audit/**",
        "src/modules/harness-parity/**",
        "src/modules/history/cli.ts",
        "src/modules/history/cli-commands.ts",
        "src/modules/knowledge/**",
        "src/modules/memory/**",
        "src/modules/module-manager/**",
        "src/modules/owner-questions/**",
        "src/modules/rendering/**",
        "src/modules/repo-tasks/**",
        "src/modules/skill-ops/**",
        "src/modules/webhook/**",
        "src/modules/workflow-ops/runs/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": {
              "level": "error",
              "options": {
                "allow": ["warn", "error"]
              }
            }
          }
        }
      }
    }
  ]
}
