# KOTA Telegram personal assistant — required secrets.
#
# Copy this file to `.env` next to docker-compose.yml (or to
# `/etc/kota/telegram-assistant.env` for the systemd path) and populate
# every required value. Leave optional values blank to disable the
# matching capability.

# ---------- Required ----------

# Anthropic API key — backs the interactive session loop.
ANTHROPIC_API_KEY=

# BotFather-issued Telegram token for the personal-assistant bot.
TELEGRAM_BOT_TOKEN=

# Chat ID that receives notification events and is authorized for
# /status. Usually the operator's private chat with the bot.
TELEGRAM_ALERT_CHAT_ID=

# ---------- Optional ----------

# OpenAI API key — when set, the whisper transcription module registers
# a provider so voice notes reach the agent as transcribed text. Without
# it, voice messages surface a clear user-facing failure rather than a
# silent drop.
OPENAI_API_KEY=
