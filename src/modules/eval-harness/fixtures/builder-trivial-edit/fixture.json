{
  "id": "builder-trivial-edit",
  "description": "Builder picks up a single ready task asking to add a tiny marker file. Fixture passes when the marker file exists and the task has moved out of ready/.",
  "role": "builder",
  "workflowName": "builder",
  "budgetMs": 1500000,
  "predicates": [
    {
      "kind": "file-exists",
      "path": "data/markers/builder-eval-ok.txt"
    },
    {
      "kind": "file-absent",
      "path": "data/tasks/ready/task-add-builder-eval-marker.md"
    }
  ],
  "objectiveMetrics": [
    {
      "name": "marker_file_count",
      "unit": "files",
      "direction": "higher_is_better",
      "source": {
        "kind": "shell",
        "command": "find data/markers -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' '"
      }
    }
  ],
  "verifierCalibration": {
    "null": {},
    "golden": {
      "setup": [
        {
          "kind": "copy-fixture-file",
          "sourcePath": "calibration/golden/builder-eval-ok.txt",
          "targetPath": "data/markers/builder-eval-ok.txt"
        }
      ]
    },
    "adversarial": {
      "setup": [
        {
          "kind": "copy-fixture-file",
          "sourcePath": "calibration/adversarial/decoy.txt",
          "targetPath": "data/not-markers/decoy.txt"
        }
      ]
    }
  },
  "tags": [
    "smoke",
    "autonomy"
  ],
  "provenance": {
    "kind": "smoke-fixture",
    "justification": "Proves the fixture → workflow → predicate plumbing works end-to-end on the minimum-viable builder path (one ready task, one file edit, one task-state move). Orthogonal to the real-failure fixtures alongside it: a regression fixture proves the agent still handles a specific past failure; this proves the harness wiring is not itself broken."
  },
  "preRunExpectations": [
    {
      "predicate": {
        "kind": "file-exists",
        "path": "data/markers/builder-eval-ok.txt"
      },
      "expected": "fail"
    },
    {
      "predicate": {
        "kind": "file-exists",
        "path": "data/tasks/ready/task-add-builder-eval-marker.md"
      },
      "expected": "pass"
    }
  ],
  "controlDecisions": [
    "act"
  ]
}
