{
  "id": "inbox-sorter-smoke",
  "description": "Inbox-sorter receives one rough idea; fixture passes when the inbox is drained and at least one normalized task has been produced in data/tasks/.",
  "role": "inbox-sorter",
  "workflowName": "inbox-sorter",
  "budgetMs": 900000,
  "predicates": [
    {
      "kind": "file-absent",
      "path": "data/inbox/rough-idea.md"
    },
    {
      "kind": "shell-succeeds",
      "command": "test \"$(find data/tasks -mindepth 1 -name 'task-*.md' -type f | wc -l | tr -d ' ')\" -ge 1"
    }
  ],
  "tags": [
    "smoke",
    "autonomy"
  ],
  "provenance": {
    "kind": "smoke-fixture",
    "justification": "Proves the inbox-sorter workflow still runs end-to-end under the harness: one rough idea in, one normalized task out, inbox drained. Orthogonal to the dedup regression fixture next door, which exercises a specific past-failure mode; this smoke fixture fails loudly when harness plumbing itself regresses."
  },
  "preRunExpectations": [
    {
      "predicate": {
        "kind": "file-absent",
        "path": "data/inbox/rough-idea.md"
      },
      "expected": "fail"
    },
    {
      "predicate": {
        "kind": "file-exists",
        "path": "data/inbox/rough-idea.md"
      },
      "expected": "pass"
    }
  ],
  "verifierCalibration": {
    "null": {},
    "golden": {
      "setup": [
        {
          "kind": "copy-fixture-file",
          "sourcePath": "calibration/golden/task-calibration-inbox-sorter-smoke.md",
          "targetPath": "data/tasks/ready/task-calibration-inbox-sorter-smoke.md"
        }
      ]
    },
    "adversarial": {
      "setup": [
        {
          "kind": "copy-fixture-file",
          "sourcePath": "calibration/adversarial/decoy.txt",
          "targetPath": "calibration-decoy.txt"
        }
      ]
    }
  },
  "controlDecisions": [
    "act"
  ]
}
