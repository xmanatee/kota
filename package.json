{
  "name": "kota",
  "version": "0.1.0",
  "description": "KOTA — Keep Only The Awesome. An AI coding agent.",
  "type": "module",
  "bin": {
    "kota": "./dist/cli.js"
  },
  "exports": {
    "./extension": {
      "types": "./dist/extension-api.d.ts",
      "default": "./dist/extension-api.js"
    }
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:workflow-critical": "vitest run src/agent-sdk/executor.test.ts src/event-bus.test.ts src/instruction-files.test.ts src/modules/daemon.test.ts src/scheduler/daemon.test.ts src/task-files.test.ts src/workflow/runtime.test.ts src/workflow/validation.test.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "validate-tasks": "node dist/validate-queue.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.77",
    "@anthropic-ai/sdk": "^0.52.0",
    "commander": "^13.1.0",
    "glob": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
