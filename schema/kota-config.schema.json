{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kota.dev/schema/kota-config.schema.json",
  "title": "KotaConfig",
  "description": "KOTA configuration file (.kota/config.json). Project-level config overrides global (~/.kota/config.json); CLI flags override both.",
  "additionalProperties": false,
  "properties": {
    "agentModels": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "Per-agent model overrides.",
      "type": "object"
    },
    "aliases": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "Prompt aliases — keys that expand into prefix text when starting a message.",
      "type": "object"
    },
    "approvalTtlMs": {
      "description": "TTL for pending approval items in milliseconds. Default: 86400000 (24 hours).",
      "type": "number"
    },
    "autoEnable": {
      "description": "Tool groups to auto-enable at session start (e.g. [\"web\", \"code\"]).",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "cli": {
      "additionalProperties": false,
      "description": "CLI entrypoint settings (interactive REPL, `history resume`, piped input).",
      "properties": {
        "defaultAutonomyMode": {
          "enum": [
            "passive",
            "supervised",
            "autonomous"
          ],
          "type": "string"
        }
      },
      "type": "object"
    },
    "daemon": {
      "additionalProperties": false,
      "description": "Daemon lifecycle settings.",
      "properties": {
        "eventBufferSize": {
          "description": "Recent SSE events retained in the in-memory ring buffer. Default: 500.",
          "type": "number"
        },
        "sessionIdleTtlMs": {
          "description": "Idle TTL for daemon-owned interactive chat sessions. Default: 5 min.",
          "type": "number"
        },
        "shutdownGracePeriodMs": {
          "description": "ms to wait for active workflow runs before aborting on shutdown. 0 = drain.",
          "type": "number"
        }
      },
      "type": "object"
    },
    "defaultAgentHarness": {
      "description": "Default agent harness adapter name. Must match a harness registered by a loaded module. No implicit default — KOTA does not silently pick one.\n\nOperators that ship a preset rarely need to set this directly: the active preset (`defaultPreset` / `--preset` / `KOTA_PRESET`) carries its own harness. This field stays for the rare case where a workflow or operator needs to pin a harness independently of the preset's harness.",
      "type": "string"
    },
    "defaultPreset": {
      "description": "Default preset id for this project. Selects harness + default model + fast/balanced/capable tier mapping + default reasoning effort + required env vars together. Resolution priority: `--preset` flag > `KOTA_PRESET` env > this field > shipped default preset. Must match a shipped preset id (`claude` | `codex` | `gemini`). When unset, KOTA selects the shipped default preset (`claude`).",
      "type": "string"
    },
    "editorModel": {
      "type": "string"
    },
    "failover": {
      "additionalProperties": false,
      "properties": {
        "apiKey": {
          "description": "Fallback API key. Resolved from env if omitted.",
          "type": "string"
        },
        "baseUrl": {
          "description": "Fallback base URL. Uses preset if omitted.",
          "type": "string"
        },
        "cooldownMs": {
          "description": "Cooldown before re-probing the primary, in ms. Default: 300000.",
          "type": "number"
        },
        "errorThreshold": {
          "description": "Errors in the sliding window that trigger failover. Default: 5.",
          "type": "number"
        },
        "model": {
          "description": "Fallback model. Falls back to the primary model if omitted.",
          "type": "string"
        },
        "provider": {
          "description": "Fallback provider name (e.g. \"openai\"). Required.",
          "type": "string"
        },
        "windowMs": {
          "description": "Sliding window in ms. Default: 60000.",
          "type": "number"
        }
      },
      "required": [
        "provider"
      ],
      "type": "object",
      "description": "Model provider failover (secondary provider when primary is unhealthy)"
    },
    "foreignModules": {
      "description": "Foreign-language (out-of-process) modules.",
      "items": {
        "anyOf": [
          {
            "additionalProperties": false,
            "description": "Stdio transport — spawns a subprocess and communicates over stdin/stdout.",
            "properties": {
              "args": {
                "description": "Arguments passed to the executable.",
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "command": {
                "description": "Executable to run (e.g. \"python3\", \"/usr/bin/ruby\").",
                "type": "string"
              },
              "cwd": {
                "description": "Working directory for the subprocess. Relative paths are resolved from the KOTA project root. Defaults to the KOTA project root.",
                "type": "string"
              },
              "env": {
                "additionalProperties": {
                  "type": "string"
                },
                "description": "Additional environment variables for the subprocess.",
                "type": "object"
              },
              "maxRestarts": {
                "description": "Maximum number of automatic restart attempts after an unexpected exit. Set to 0 to disable restart. Default: 3.",
                "type": "number"
              },
              "pingIntervalMs": {
                "description": "How often (ms) to send a health-check ping. Default: 30000. Set to 0 to disable periodic pings.",
                "type": "number"
              },
              "pingTimeoutMs": {
                "description": "Milliseconds to wait for a `pong` response before declaring the subprocess hung and triggering a restart. Default: 5000. Set to 0 to disable pings.",
                "type": "number"
              },
              "restartBackoffBaseMs": {
                "description": "Base milliseconds for exponential restart backoff. Default: 2000.",
                "type": "number"
              },
              "transport": {
                "const": "stdio",
                "type": "string"
              }
            },
            "required": [
              "transport",
              "command"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "description": "HTTP transport — connects to an already-running HTTP server that speaks KEMP.",
            "properties": {
              "bearerToken": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "additionalProperties": false,
                    "properties": {
                      "env": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "env"
                    ],
                    "type": "object"
                  }
                ],
                "description": "Optional bearer token sent as `Authorization: Bearer <token>` on every request. Supply a string literal or `{ env: \"ENV_VAR_NAME\" }` to read from an environment variable. The token is never logged."
              },
              "transport": {
                "const": "http",
                "type": "string"
              },
              "url": {
                "description": "Base URL of the KEMP HTTP server (e.g. \"http://localhost:8765\").",
                "type": "string"
              }
            },
            "required": [
              "transport",
              "url"
            ],
            "type": "object"
          }
        ],
        "description": "Configuration for a single foreign-language module entry."
      },
      "type": "array"
    },
    "guardrails": {
      "additionalProperties": false,
      "properties": {
        "approvalTimeoutMs": {
          "description": "TTL in ms for approval requests created in this context. Stored on each queued item.",
          "type": "number"
        },
        "policies": {
          "additionalProperties": false,
          "description": "Policy applied at each risk level.",
          "properties": {
            "dangerous": {
              "enum": [
                "allow",
                "confirm",
                "deny",
                "queue"
              ],
              "type": "string"
            },
            "moderate": {
              "enum": [
                "allow",
                "confirm",
                "deny",
                "queue"
              ],
              "type": "string"
            },
            "safe": {
              "enum": [
                "allow",
                "confirm",
                "deny",
                "queue"
              ],
              "type": "string"
            }
          },
          "required": [
            "safe",
            "moderate",
            "dangerous"
          ],
          "type": "object"
        },
        "toolOverrides": {
          "additionalProperties": {
            "enum": [
              "allow",
              "confirm",
              "deny",
              "queue"
            ],
            "type": "string"
          },
          "description": "Override policy for specific tool names (bypasses risk classification).",
          "type": "object"
        }
      },
      "required": [
        "policies"
      ],
      "type": "object"
    },
    "log": {
      "additionalProperties": false,
      "description": "Log output settings.",
      "properties": {
        "format": {
          "description": "\"text\" is human-readable (default); \"json\" emits newline-delimited JSON.",
          "enum": [
            "text",
            "json"
          ],
          "type": "string"
        }
      },
      "type": "object"
    },
    "maxTokens": {
      "type": "number"
    },
    "mcp": {
      "additionalProperties": false,
      "properties": {
        "sampling": {
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "description": "Enable the sampling/createMessage handler. Default: false.",
              "type": "boolean"
            }
          },
          "type": "object"
        }
      },
      "type": "object",
      "description": "MCP server and sampling configuration"
    },
    "model": {
      "type": "string"
    },
    "modelProvider": {
      "additionalProperties": false,
      "properties": {
        "apiKey": {
          "type": "string"
        },
        "baseUrl": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "type": "object",
      "description": "Non-Anthropic model provider (OpenAI-compat, Ollama, etc.)"
    },
    "modelTiers": {
      "additionalProperties": false,
      "properties": {
        "balanced": {
          "type": "string"
        },
        "capable": {
          "type": "string"
        },
        "fast": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "moduleMonitoring": {
      "additionalProperties": false,
      "description": "Foreign module health monitoring settings.",
      "properties": {
        "crashAlertThreshold": {
          "description": "Restarts within `crashAlertWindowMs` that trigger `module.crash.alert`.",
          "type": "number"
        },
        "crashAlertWindowMs": {
          "description": "Rolling window for counting module restarts. Also alert cooldown.",
          "type": "number"
        }
      },
      "type": "object"
    },
    "modules": {
      "additionalProperties": {
        "additionalProperties": {},
        "type": "object"
      },
      "description": "Per-module configuration. Keys are module names, values are module-specific settings.",
      "type": "object",
      "properties": {
        "slack-channel": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "botToken",
            "appToken"
          ],
          "properties": {
            "botToken": {
              "type": "string",
              "minLength": 1
            },
            "appToken": {
              "type": "string",
              "minLength": 1
            },
            "notifyChannel": {
              "type": "string",
              "minLength": 1
            },
            "defaultAutonomyMode": {
              "type": "string",
              "enum": [
                "passive",
                "supervised",
                "autonomous"
              ]
            }
          }
        },
        "telegram": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "events": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "defaultAutonomyMode": {
              "type": "string",
              "enum": [
                "passive",
                "supervised",
                "autonomous"
              ]
            },
            "allowedChatIds": {
              "type": "array",
              "items": {
                "type": "integer"
              },
              "uniqueItems": true
            }
          }
        },
        "transcription-whisper": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "apiKey"
          ],
          "properties": {
            "apiKey": {
              "type": "string",
              "minLength": 1
            },
            "baseUrl": {
              "type": "string",
              "minLength": 1
            },
            "model": {
              "type": "string",
              "minLength": 1
            },
            "timeoutMs": {
              "type": "number",
              "minimum": 1000
            },
            "maxRetries": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "vercel-adapter": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "defaultAutonomyMode": {
              "type": "string",
              "enum": [
                "passive",
                "supervised",
                "autonomous"
              ]
            }
          }
        },
        "voice-openai-tts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "apiKey"
          ],
          "properties": {
            "apiKey": {
              "type": "string",
              "minLength": 1
            },
            "baseUrl": {
              "type": "string",
              "minLength": 1
            },
            "model": {
              "type": "string",
              "minLength": 1
            },
            "defaultVoice": {
              "type": "string",
              "minLength": 1
            },
            "defaultFormat": {
              "type": "string",
              "enum": [
                "mp3",
                "wav",
                "ogg",
                "opus",
                "aac",
                "flac",
                "pcm"
              ]
            },
            "timeoutMs": {
              "type": "number",
              "minimum": 1000
            },
            "maxRetries": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "voice-whisper-local": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "binaryPath",
            "modelPath"
          ],
          "properties": {
            "binaryPath": {
              "type": "string",
              "minLength": 1
            },
            "modelPath": {
              "type": "string",
              "minLength": 1
            },
            "extraArgs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "timeoutMs": {
              "type": "number",
              "minimum": 1000
            }
          }
        },
        "webhook-channel": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "secret": {
              "type": "string",
              "minLength": 1
            },
            "defaultAgent": {
              "type": "string",
              "minLength": 1
            },
            "defaultAutonomyMode": {
              "type": "string",
              "enum": [
                "passive",
                "supervised",
                "autonomous"
              ]
            },
            "sources": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "agent"
                ],
                "properties": {
                  "agent": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      }
    },
    "notifications": {
      "additionalProperties": false,
      "description": "Notification settings.",
      "properties": {
        "alertCooldownMs": {
          "description": "Minimum ms between failure alerts for the same workflow. Default: 0.",
          "type": "number"
        },
        "quietHours": {
          "additionalProperties": false,
          "properties": {
            "allowCritical": {
              "description": "When true (default), critical events bypass quiet hours. Critical: workflow.failure.alert, module.crash.alert.",
              "type": "boolean"
            },
            "end": {
              "description": "Quiet period end in local time, \"HH:MM\" (24-hour). Spans crossing midnight are supported.",
              "type": "string"
            },
            "start": {
              "description": "Quiet period start in local time, \"HH:MM\" (24-hour).",
              "type": "string"
            }
          },
          "required": [
            "start",
            "end"
          ],
          "type": "object"
        }
      },
      "type": "object"
    },
    "providers": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "Provider overrides. Keys are service types (e.g. \"memory\"), values are provider names.",
      "type": "object"
    },
    "reflection": {
      "description": "Self-reflection — evaluate response quality before delivering. Default: true.",
      "type": "boolean"
    },
    "runsGc": {
      "additionalProperties": false,
      "description": "Run artifact retention policy for `.kota/runs/`.",
      "properties": {
        "minKeepPerWorkflow": {
          "description": "Always keep at least this many recent runs per workflow (default: 10).",
          "type": "number"
        },
        "retentionDays": {
          "description": "Delete runs older than this many days (default: 7).",
          "type": "number"
        }
      },
      "type": "object"
    },
    "scheduler": {
      "additionalProperties": false,
      "properties": {
        "agentConcurrency": {
          "description": "Max simultaneous agent-step workflows. Must be a positive integer. Default: 1.",
          "type": "number"
        },
        "codeConcurrency": {
          "description": "Max simultaneous code-only workflows. Must be a positive integer. Default: 4.",
          "type": "number"
        },
        "dispatchWindow": {
          "additionalProperties": false,
          "description": "Dispatch window — time-of-day and day-of-week restriction for autonomous workflow triggers.\n\nAffects `runtime.idle` (idle trigger) and `intervalMs` (interval trigger) only. Cron, event, file-watch, and manual triggers are not affected.",
          "properties": {
            "days": {
              "description": "Days on which the window applies. Default: all days. Accepted values: \"mon\" | \"tue\" | \"wed\" | \"thu\" | \"fri\" | \"sat\" | \"sun\"",
              "items": {
                "enum": [
                  "mon",
                  "tue",
                  "wed",
                  "thu",
                  "fri",
                  "sat",
                  "sun"
                ],
                "type": "string"
              },
              "type": "array"
            },
            "end": {
              "description": "End of allowed window in local time, \"HH:MM\" (24-hour, exclusive).",
              "type": "string"
            },
            "start": {
              "description": "Start of allowed window in local time, \"HH:MM\" (24-hour).",
              "type": "string"
            }
          },
          "required": [
            "start",
            "end"
          ],
          "type": "object"
        }
      },
      "type": "object",
      "description": "Scheduler dispatch window and concurrency settings"
    },
    "serve": {
      "additionalProperties": false,
      "description": "HTTP server settings for `kota serve`.",
      "properties": {
        "defaultAutonomyMode": {
          "enum": [
            "passive",
            "supervised",
            "autonomous"
          ],
          "type": "string"
        },
        "noAuth": {
          "description": "Disable bearer-token auth (default: auth enabled). For localhost-only dev use.",
          "type": "boolean"
        },
        "showCost": {
          "description": "Show per-turn cost line in terminal output (default: true).",
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "skipConfirmations": {
      "type": "boolean"
    },
    "thinking": {
      "type": "boolean"
    },
    "thinkingBudget": {
      "type": "number"
    },
    "tracing": {
      "additionalProperties": false,
      "properties": {
        "endpoint": {
          "description": "OTLP HTTP endpoint (e.g. \"http://localhost:4318/v1/traces\"). Required to enable.",
          "type": "string"
        },
        "metricsEndpoint": {
          "description": "OTLP HTTP endpoint for metrics. Defaults to `endpoint`.",
          "type": "string"
        },
        "metricsExportIntervalMs": {
          "description": "Metric flush interval. Default: 30 000.",
          "type": "number"
        },
        "samplingRate": {
          "description": "Sampling rate between 0 and 1. Default: 1.0.",
          "type": "number"
        },
        "serviceName": {
          "description": "Service name reported in traces. Default: \"kota\".",
          "type": "string"
        }
      },
      "required": [
        "endpoint"
      ],
      "type": "object",
      "description": "OpenTelemetry trace export endpoint and sampling config"
    },
    "user": {
      "additionalProperties": false,
      "description": "User profile — injected into system prompt for personalization.",
      "properties": {
        "context": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "verbose": {
      "type": "boolean"
    },
    "webhooks": {
      "additionalProperties": {
        "additionalProperties": false,
        "properties": {
          "secret": {
            "type": "string"
          }
        },
        "required": [
          "secret"
        ],
        "type": "object"
      },
      "type": "object",
      "description": "Per-workflow webhook secrets for signature verification"
    },
    "workflow": {
      "additionalProperties": false,
      "description": "Workflow runtime settings.",
      "properties": {
        "maxStepOutputBytes": {
          "description": "Max step output bytes before truncation. Default: 256 KB. Hard cap: 10 MB.",
          "type": "number"
        }
      },
      "type": "object"
    }
  },
  "type": "object"
}
